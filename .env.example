# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Groq LLM (optional — without it, reasoning falls back to offline templates)
GROQ_API_KEY=your-groq-api-key-here

# Optional validation tunables (defaults shown)
# ASSET_CLASS=product
# ASSEMBLY_MIN_COMPONENTS=8
# ASSEMBLY_MIN_SUBSTANTIAL_PARTS=3
# SUBSTANTIAL_PART_MIN_FACES=200
